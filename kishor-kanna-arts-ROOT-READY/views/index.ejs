<% pageTitle = 'Home' %>
<%- include('partials/header') %>

<section class="hero<%= settings.hero_image_url ? ' hero-with-image' : '' %>" <% if (settings.hero_image_url) { %>style="background-image: linear-gradient(180deg, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.1) 35%, rgba(0,0,0,0.55) 100%), url('<%= settings.hero_image_url %>');"<% } %>>
  <div class="hero-inner">
    <h1><%= settings.hero_title %></h1>
    <p><%= settings.hero_subtitle %></p>
    <div class="hero-buttons">
      <a class="btn" href="/order">Order Your Artwork</a>
      <a class="btn btn-outline<%= settings.hero_image_url ? ' btn-outline-onimage' : '' %>" href="/portfolio">View Portfolio</a>
    </div>
  </div>
</section>

<% if (offers.length) { %>
<div class="container" style="margin-bottom:10px;">
  <% offers.forEach(o => { %>
    <div style="background:#fff2cc; border:1px solid #e6cf87; border-radius:10px; padding:14px 20px; margin-bottom:12px; text-align:center;">
      <strong><%= o.title %></strong>
      <% if (o.message) { %> — <%= o.message %><% } %>
    </div>
  <% }) %>
</div>
<% } %>

<section class="section">
  <h2>Featured Portfolio</h2>
  <p class="sub">A glimpse of recent handcrafted pieces</p>
  <div class="grid">
    <% featured.forEach(a => { %>
      <a class="card" href="/portfolio/<%= a.id %>">
        <img src="<%= a.image || 'https://placehold.co/400x300?text=Artwork' %>" alt="<%= a.title %>">
        <div class="card-body">
          <span class="tag"><%= a.category %></span>
          <h3><%= a.title %></h3>
          <p><%= a.description %></p>
        </div>
      </a>
    <% }) %>
    <% if (featured.length === 0) { %>
      <p class="sub">No artworks added yet — add some from the admin panel.</p>
    <% } %>
  </div>
</section>

<section class="section section-tint">
  <h2>Services</h2>
  <p class="sub">Custom art made to order</p>
  <div class="grid">
    <% services.forEach(s => { %>
      <div class="card">
        <img src="<%= s.image || 'https://placehold.co/400x300?text=Service' %>" alt="<%= s.title %>">
        <div class="card-body">
          <h3><%= s.title %></h3>
          <p><%= s.description %></p>
          <a class="btn btn-outline" href="/order">Order This</a>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<section class="section">
  <h2>Why Choose Us</h2>
  <div class="grid">
    <div class="card"><div class="card-body"><h3>100% Hand-made</h3><p>Every artwork is drawn or painted by hand, never printed.</p></div></div>
    <div class="card"><div class="card-body"><h3>Made From Your Photos</h3><p>Send a photo and we turn it into a keepsake artwork.</p></div></div>
    <div class="card"><div class="card-body"><h3>Tracked Orders</h3><p>Follow your order status from start to delivery.</p></div></div>
    <div class="card"><div class="card-body"><h3>Nationwide Delivery</h3><p>Carefully packed and shipped anywhere in India.</p></div></div>
  </div>
</section>

<% if (videos.length) { %>
<section class="section section-tint">
  <h2>Videos</h2>
  <p class="sub">Watch the artwork process</p>

  <div class="videos-marquee">
    <div class="videos-track" id="videosTrack">
      <% videos.forEach(v => { %>
        <div class="video-card">
          <div class="card">
            <div class="card-body">
              <h3><%= v.title %></h3>
              <% if (v.embed_url) { %>
                <div style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:8px;">
                  <iframe src="<%= v.embed_url %>" style="position:absolute; top:0; left:0; width:100%; height:100%;" frameborder="0" loading="lazy" allow="autoplay; encrypted-media" allowfullscreen></iframe>
                </div>
              <% } else { %>
                <a class="btn btn-outline" href="<%= v.video_url %>" target="_blank" rel="noopener">Watch Video</a>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<script>
  (function () {
    const track = document.getElementById('videosTrack');
    if (!track) return;
    Array.from(track.children).forEach(card => track.appendChild(card.cloneNode(true)));
  })();
</script>
<% } %>

<% if (testimonials.length) { %>
<section class="section">
  <h2>Reviews</h2>
  <p class="sub">What our customers say</p>
  <div class="reviews-marquee">
    <div class="reviews-track" id="reviewsTrack">
      <% testimonials.forEach(t => {
        const headline = t.message.length > 55 ? t.message.slice(0, 55).trim() + '…' : t.message;
        const needsReadMore = t.message.length > 140;
      %>
        <div class="testimonial">
          <div class="quote-mark">&ldquo;</div>
          <div class="review-title"><%= headline %></div>
          <div class="review-body"><%= t.message %></div>
          <% if (needsReadMore) { %>
            <button type="button" class="read-more" onclick="const c=this.closest('.testimonial'); c.classList.toggle('expanded'); this.textContent = c.classList.contains('expanded') ? 'READ LESS' : 'READ MORE';">READ MORE</button>
          <% } %>
          <div class="stars"><%= '★'.repeat(t.rating) %><%= '☆'.repeat(5 - t.rating) %></div>
          <div class="who-row"><span class="who"><%= t.name %></span></div>
          <div class="meta-row">
            <span class="verified">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              Verified
            </span>
            <span class="review-date" data-created="<%= t.created_at %>">just now</span>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<script>
  (function () {
    function timeAgo(iso) {
      const diff = Date.now() - new Date(iso).getTime();
      const day = 86400000;
      const days = Math.floor(diff / day);
      if (days <= 0) return 'Today';
      if (days === 1) return '1 day ago';
      if (days < 30) return days + ' days ago';
      const months = Math.floor(days / 30);
      if (months < 12) return months + (months === 1 ? ' month ago' : ' months ago');
      const years = Math.floor(months / 12);
      return years + (years === 1 ? ' year ago' : ' years ago');
    }
    document.querySelectorAll('.review-date[data-created]').forEach(el => {
      el.textContent = timeAgo(el.getAttribute('data-created'));
    });

    const track = document.getElementById('reviewsTrack');
    if (!track) return;
    Array.from(track.children).forEach(card => track.appendChild(card.cloneNode(true)));
  })();
</script>
<% } %>

<section class="section section-tint" style="text-align:center;">
  <h2>Ready to Order Your Custom Artwork?</h2>
  <p class="sub">Tell us your idea — we'll bring it to life.</p>
  <a class="btn" href="/order">Start Your Order</a>
</section>

<%- include('partials/footer') %>
