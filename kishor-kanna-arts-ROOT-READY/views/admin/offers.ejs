<!DOCTYPE html>
<html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Offers / Updates | Admin</title><link rel="stylesheet" href="/public/css/admin.css"></head>
<body class="admin">
<div class="admin-shell">
  <% active = 'offers' %>
  <%- include('partials/sidebar') %>
  <div class="admin-main">
    <div class="admin-topbar"><h1>Offers / Updates</h1></div>
    <p style="color:var(--muted); font-size:0.9rem; margin-top:-10px;">These show as a banner on your homepage. Turn one off anytime without deleting it.</p>

    <table style="margin-bottom:30px;">
      <tr><th>Title</th><th>Message</th><th>Status</th><th>Actions</th></tr>
      <% offers.forEach(o => { %>
        <tr>
          <td><%= o.title %></td>
          <td><%= o.message %></td>
          <td><span class="badge <%= o.active ? 'badge-ok' : 'badge-new' %>"><%= o.active ? 'Live' : 'Off' %></span></td>
          <td class="actions-row">
            <form action="/admin/offers/<%= o.id %>/toggle" method="POST">
              <button class="btn btn-ghost btn-sm" type="submit"><%= o.active ? 'Turn Off' : 'Turn On' %></button>
            </form>
            <form action="/admin/offers/<%= o.id %>/delete" method="POST" onsubmit="return confirm('Delete this offer?');">
              <button class="btn btn-danger btn-sm" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (offers.length === 0) { %><tr><td colspan="4">No offers yet.</td></tr><% } %>
    </table>

    <h2 style="font-size:1.1rem;">Add Offer / Update</h2>
    <form class="admin-form" action="/admin/offers/save" method="POST">
      <div class="form-group"><label>Title</label><input type="text" name="title" required placeholder="e.g. 20% Off This Week"></div>
      <div class="form-group"><label>Discount % (optional)</label><input type="number" name="discount_percent" min="0" max="100" placeholder="e.g. 20"></div>
      <button class="btn btn-primary" type="submit">Publish</button>
    </form>
  </div>
</div>
</body></html>
