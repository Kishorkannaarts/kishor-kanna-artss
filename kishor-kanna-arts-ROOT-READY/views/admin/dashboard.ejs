<!DOCTYPE html>
<html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard | Admin</title><link rel="stylesheet" href="/public/css/admin.css"></head>
<body class="admin">
<div class="admin-shell">
  <% active = 'dashboard' %>
  <%- include('partials/sidebar') %>
  <div class="admin-main">
    <div class="admin-topbar"><h1>Dashboard</h1></div>

    <div class="top-actions actions-row">
      <a class="btn btn-primary btn-sm" href="/admin/artworks/new">+ Add Artwork</a>
      <a class="btn btn-ghost btn-sm" href="/admin/offers">+ New Offer</a>
      <a class="btn btn-ghost btn-sm" href="/admin/orders">View All Orders</a>
      <a class="btn btn-ghost btn-sm" href="/admin/messages">Contact Messages<% if (counts.messages > 0) { %> (<%= counts.messages %>)<% } %></a>
    </div>

    <div class="stat-grid">
      <div class="stat-card"><div class="num">₹<%= finance.totalReceived.toFixed(0) %></div><div class="label">Total Received</div></div>
      <div class="stat-card"><div class="num">₹<%= finance.totalPending.toFixed(0) %></div><div class="label">Pending Payments</div></div>
      <div class="stat-card"><div class="num">₹<%= finance.totalExpenses.toFixed(0) %></div><div class="label">Total Expenses</div></div>
      <div class="stat-card"><div class="num">₹<%= finance.totalProfit.toFixed(0) %></div><div class="label">Net Profit</div></div>
    </div>
    <p style="color:var(--muted); font-size:0.85rem; margin-top:-14px;">Add expenses per order on the Orders page — profit here is Total Received minus Total Expenses across all orders.</p>

    <div class="stat-grid">
      <div class="stat-card"><div class="num"><%= counts.artworks %></div><div class="label">Artworks</div></div>
      <div class="stat-card"><div class="num"><%= counts.orders %></div><div class="label">Total Orders</div></div>
      <div class="stat-card"><div class="num"><%= counts.newOrders %></div><div class="label">New Orders</div></div>
      <div class="stat-card"><div class="num"><%= counts.messages %></div><div class="label">Unread Messages</div></div>
      <div class="stat-card"><div class="num"><%= counts.testimonials %></div><div class="label">Reviews Pending</div></div>
      <div class="stat-card"><div class="num"><%= counts.subscribers %></div><div class="label">Newsletter Subscribers</div></div>
    </div>

    <h2 style="font-size:1.1rem;">Recent Orders</h2>
    <table>
      <tr><th>Order ID</th><th>Name</th><th>Art Type</th><th>Status</th><th>Placed</th></tr>
      <% recentOrders.forEach(o => { %>
        <tr>
          <td><%= o.order_code %></td>
          <td><%= o.name %></td>
          <td><%= o.art_type %></td>
          <td><span class="badge <%= statusBadgeClass(o.status) %>"><%= o.status %></span></td>
          <td><%= o.created_at %></td>
        </tr>
      <% }) %>
      <% if (recentOrders.length === 0) { %><tr><td colspan="5">No orders yet.</td></tr><% } %>
    </table>
  </div>
</div>
</body></html>
