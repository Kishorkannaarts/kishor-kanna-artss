<!DOCTYPE html>
<html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= artwork ? 'Edit' : 'Add' %> Artwork | Admin</title><link rel="stylesheet" href="/public/css/admin.css"></head>
<body class="admin">
<div class="admin-shell">
  <% active = 'artworks' %>
  <%- include('partials/sidebar') %>
  <div class="admin-main">
    <div class="admin-topbar"><h1><%= artwork ? 'Edit' : 'Add' %> Artwork</h1></div>
    <form class="admin-form" action="/admin/artworks/save" method="POST" enctype="multipart/form-data">
      <% if (artwork) { %><input type="hidden" name="id" value="<%= artwork.id %>"><% } %>
      <div class="form-group">
        <label>Title</label>
        <input type="text" name="title" value="<%= artwork ? artwork.title : '' %>" required>
      </div>
      <div class="form-group">
        <label>Category</label>
        <select name="category" required>
          <% ['Pencil Art','Pen Art','Blood Art','Colour Art','Canvas Art'].forEach(c => { %>
            <option value="<%= c %>" <%= artwork && artwork.category === c ? 'selected' : '' %>><%= c %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description"><%= artwork ? artwork.description : '' %></textarea>
      </div>
      <div class="form-group">
        <label>Story (optional background story of the piece)</label>
        <textarea name="story"><%= artwork ? artwork.story : '' %></textarea>
      </div>
      <div class="form-group">
        <label>Size</label>
        <input type="text" name="size" value="<%= artwork ? artwork.size : '' %>" placeholder="e.g. A4">
      </div>
      <div class="form-group">
        <label>Price</label>
        <input type="text" name="price" value="<%= artwork ? artwork.price : '' %>" placeholder="e.g. ₹1500">
      </div>
      <div class="form-group">
        <label>Image (upload to <%= artwork && artwork.image ? 'replace current image' : 'add image' %>)</label>
        <% if (artwork && artwork.image) { %><img class="thumb" src="<%= artwork.image %>" style="margin-bottom:10px;"><% } %>
        <input type="file" name="image" accept="image/*">
      </div>
      <div class="form-group">
        <label><input type="checkbox" name="featured" style="width:auto; display:inline;" <%= artwork && artwork.featured ? 'checked' : '' %>> Show on Home Page (Featured)</label>
      </div>
      <button class="btn btn-primary" type="submit">Save Artwork</button>
      <a class="btn btn-ghost" href="/admin/artworks">Cancel</a>
    </form>
  </div>
</div>
</body></html>
