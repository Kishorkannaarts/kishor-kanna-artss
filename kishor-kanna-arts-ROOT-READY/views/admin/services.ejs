<!DOCTYPE html>
<html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Services | Admin</title><link rel="stylesheet" href="/public/css/admin.css"></head>
<body class="admin">
<div class="admin-shell">
  <% active = 'services' %>
  <%- include('partials/sidebar') %>
  <div class="admin-main">
    <div class="admin-topbar"><h1>Services</h1></div>

    <p style="color:var(--muted); font-size:0.85rem; margin-top:-16px;">
      Price columns come from <a href="/admin/taxonomy">Art Types &amp; Sizes</a> — add a size there and a price field for it appears here automatically.
    </p>

    <table style="margin-bottom:30px;">
      <tr><th>Image</th><th>Title</th><% sizes.forEach(sz => { %><th><%= sz %></th><% }) %><th>Actions</th></tr>
      <% services.forEach(s => { %>
        <tr>
          <td><img class="thumb" src="<%= s.image || 'https://placehold.co/60x60' %>"></td>
          <td><%= s.title %></td>
          <% sizes.forEach(sz => { %><td><%= priceForSize(s, sz) %></td><% }) %>
          <td>
            <form action="/admin/services/<%= s.id %>/delete" method="POST" onsubmit="return confirm('Delete this service?');">
              <button class="btn btn-danger btn-sm" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (services.length === 0) { %><tr><td colspan="<%= sizes.length + 3 %>">No services yet.</td></tr><% } %>
    </table>

    <h2 style="font-size:1.1rem;">Add Service</h2>
    <form class="admin-form" action="/admin/services/save" method="POST" enctype="multipart/form-data">
      <div class="form-group"><label>Title</label><input type="text" name="title" required></div>
      <div class="form-group"><label>Description</label><textarea name="description"></textarea></div>
      <div class="form-group"><label>Image</label><input type="file" name="image" accept="image/*"></div>
      <% sizes.forEach(sz => { %>
        <div class="form-group"><label>Price - <%= sz %><%= sz.toLowerCase() === 'custom' ? ' (starting from)' : '' %></label><input type="text" name="prices[<%= sz %>]"></div>
      <% }) %>
      <button class="btn btn-primary" type="submit">Save Service</button>
    </form>
  </div>
</div>
</body></html>
