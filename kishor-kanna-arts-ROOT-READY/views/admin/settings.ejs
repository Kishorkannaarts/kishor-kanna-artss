<!DOCTYPE html>
<html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Settings | Admin</title><link rel="stylesheet" href="/public/css/admin.css"></head>
<body class="admin">
<div class="admin-shell">
  <% active = 'settings' %>
  <%- include('partials/sidebar') %>
  <div class="admin-main">
    <div class="admin-topbar"><h1>Site Settings</h1></div>
    <form class="admin-form" action="/admin/settings/save" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>Logo</label>
        <% if (settings.logo_url) { %><img src="<%= settings.logo_url %>" style="height:50px; margin-bottom:10px; display:block;"><% } %>
        <input type="file" name="logo" accept="image/*">
      </div>
      <div class="form-group"><label>Site Name</label><input type="text" name="site_name" value="<%= settings.site_name %>"></div>
      <div class="form-group"><label>Home Banner Title</label><input type="text" name="hero_title" value="<%= settings.hero_title %>"></div>
      <div class="form-group"><label>Home Banner Subtitle</label><input type="text" name="hero_subtitle" value="<%= settings.hero_subtitle %>"></div>
      <div class="form-group"><label>About Us Text</label><textarea name="about_text"><%= settings.about_text %></textarea></div>
      <div class="form-group"><label>Contact Phone</label><input type="text" name="contact_phone" value="<%= settings.contact_phone %>"></div>
      <div class="form-group"><label>Contact Email</label><input type="text" name="contact_email" value="<%= settings.contact_email %>"></div>
      <div class="form-group"><label>Contact Address</label><input type="text" name="contact_address" value="<%= settings.contact_address %>"></div>

      <div class="form-group">
        <label>Google Maps Embed Link</label>
        <small style="color:var(--muted); display:block; margin-bottom:6px;">
          On Google Maps: search your business/location → click Share → Embed a map → copy the link inside <code>src="..."</code> and paste it here.
        </small>
        <input type="text" name="google_maps_embed" value="<%= settings.google_maps_embed %>" placeholder="https://www.google.com/maps/embed?pb=...">
      </div>
      <div class="form-group">
        <label>Google Business Profile / Reviews Link</label>
        <small style="color:var(--muted); display:block; margin-bottom:6px;">Link to your Google Business page so customers can read/leave Google reviews.</small>
        <input type="text" name="google_business_url" value="<%= settings.google_business_url %>" placeholder="https://g.page/r/....">
      </div>

      <div class="form-group"><label>Instagram URL</label><input type="text" name="instagram_url" value="<%= settings.instagram_url %>"></div>
      <div class="form-group"><label>Facebook URL</label><input type="text" name="facebook_url" value="<%= settings.facebook_url %>"></div>
      <div class="form-group"><label>WhatsApp Number</label><input type="text" name="whatsapp_number" value="<%= settings.whatsapp_number %>"></div>
      <button class="btn btn-primary" type="submit">Save Settings</button>
    </form>
  </div>
</div>
</body></html>
