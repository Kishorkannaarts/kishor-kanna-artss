<!DOCTYPE html>
<html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Settings | Admin</title><link rel="stylesheet" href="/public/css/admin.css"></head>
<body class="admin">
<div class="admin-shell">
  <% active = 'settings' %>
  <%- include('partials/sidebar') %>
  <div class="admin-main">
    <div class="admin-topbar"><h1>Site Settings</h1></div>
    <form class="admin-form" action="/admin/settings/save" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>Logo</label>
        <% if (settings.logo_url) { %><img src="<%= settings.logo_url %>" style="height:50px; margin-bottom:10px; display:block;"><% } %>
        <input type="file" name="logo" accept="image/*">
      </div>
      <div class="form-group">
        <label>Hero Background Image (shown behind "Art That Tells Your Story")</label>
        <% if (settings.hero_image_url) { %><img src="<%= settings.hero_image_url %>" style="max-width:260px; margin-bottom:10px; display:block; border-radius:8px;"><% } %>
        <input type="file" name="hero_image" accept="image/*">
      </div>
      <div class="form-group"><label>Site Name</label><input type="text" name="site_name" value="<%= settings.site_name %>"></div>
      <div class="form-group"><label>Home Banner Title</label><input type="text" name="hero_title" value="<%= settings.hero_title %>"></div>
      <div class="form-group"><label>Home Banner Subtitle</label><input type="text" name="hero_subtitle" value="<%= settings.hero_subtitle %>"></div>
      <div class="form-group"><label>About Us Text</label><textarea name="about_text"><%= settings.about_text %></textarea></div>
      <div class="form-group">
        <label>SEO Meta Description (shows in Google search results)</label>
        <small style="color:var(--muted); display:block; margin-bottom:6px;">Keep it under 160 characters. Mention your art types, sizes and location/city.</small>
        <textarea name="meta_description"><%= settings.meta_description %></textarea>
      </div>
      <div class="form-group">
        <label>SEO Keywords</label>
        <small style="color:var(--muted); display:block; margin-bottom:6px;">Comma-separated words people search for, e.g. pencil sketch artist, custom canvas painting.</small>
        <textarea name="meta_keywords"><%= settings.meta_keywords %></textarea>
      </div>
      <div class="form-group"><label>Contact Phone</label><input type="text" name="contact_phone" value="<%= settings.contact_phone %>"></div>
      <div class="form-group"><label>Contact Email</label><input type="text" name="contact_email" value="<%= settings.contact_email %>"></div>
      <div class="form-group"><label>Contact Address</label><input type="text" name="contact_address" value="<%= settings.contact_address %>"></div>

      <div class="form-group">
        <label>Google Maps Embed Link</label>
        <small style="color:var(--muted); display:block; margin-bottom:6px;">
          On Google Maps: search your business/location → click Share → Embed a map → copy the link inside <code>src="..."</code> and paste it here.
        </small>
        <input type="text" name="google_maps_embed" value="<%= settings.google_maps_embed %>" placeholder="https://www.google.com/maps/embed?pb=...">
      </div>
      <div class="form-group">
        <label>Google Business Profile / Reviews Link</label>
        <small style="color:var(--muted); display:block; margin-bottom:6px;">Link to your Google Business page so customers can read/leave Google reviews.</small>
        <input type="text" name="google_business_url" value="<%= settings.google_business_url %>" placeholder="https://g.page/r/....">
      </div>

      <div class="form-group"><label>Instagram URL</label><input type="text" name="instagram_url" value="<%= settings.instagram_url %>" placeholder="https://instagram.com/yourpage"></div>
      <div class="form-group"><label>Facebook URL</label><input type="text" name="facebook_url" value="<%= settings.facebook_url %>" placeholder="https://facebook.com/yourpage"></div>
      <div class="form-group"><label>YouTube Channel URL</label><input type="text" name="youtube_url" value="<%= settings.youtube_url %>" placeholder="https://youtube.com/@yourchannel"></div>
      <div class="form-group"><label>WhatsApp Number</label><input type="text" name="whatsapp_number" value="<%= settings.whatsapp_number %>"></div>
      <div class="form-group"><label>WhatsApp Popup Default Message</label><input type="text" name="whatsapp_default_message" value="<%= settings.whatsapp_default_message %>" placeholder="e.g. Hi! I'm interested in a custom artwork."></div>

      <h3 style="margin-top:24px;">Website Colors</h3>
      <div class="form-group"><label>Accent Color (buttons, links, highlights)</label><input type="color" name="theme_accent" value="<%= settings.theme_accent || '#b5451b' %>"></div>
      <div class="form-group"><label>Accent Hover/Dark Color</label><input type="color" name="theme_accent_dark" value="<%= settings.theme_accent_dark || '#8c3413' %>"></div>
      <div class="form-group"><label>Gold/Star Color (ratings)</label><input type="color" name="theme_gold" value="<%= settings.theme_gold || '#c99a3a' %>"></div>
      <div class="form-group"><label>Background Color</label><input type="color" name="theme_paper" value="<%= settings.theme_paper || '#faf6f0' %>"></div>
      <div class="form-group"><label>Text Color</label><input type="color" name="theme_ink" value="<%= settings.theme_ink || '#221a16' %>"></div>

      <button class="btn btn-primary" type="submit">Save Settings</button>
    </form>
  </div>
</div>
</body></html>
