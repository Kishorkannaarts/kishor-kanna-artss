<% pageTitle = 'Blog' %>
<%- include('partials/header') %>

<section class="section">
  <h2>Blog</h2>
  <p class="sub">Stories, tips, and behind-the-scenes from our art studio</p>

  <div class="grid">
    <% posts.forEach(p => { %>
      <a class="card" href="/blog/<%= p.slug %>" style="text-decoration:none; color:inherit;">
        <img src="<%= p.cover_image || 'https://placehold.co/400x300?text=Blog' %>" alt="<%= p.title %>" loading="lazy" decoding="async">
        <div class="card-body">
          <h3><%= p.title %></h3>
          <p><%= p.excerpt %></p>
          <span class="btn btn-outline btn-sm" style="display:inline-block; margin-top:6px;">Read More</span>
        </div>
      </a>
    <% }) %>
    <% if (posts.length === 0) { %>
      <p class="sub">No blog posts yet — check back soon.</p>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
