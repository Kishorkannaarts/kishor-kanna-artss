<% pageTitle = 'About Us' %>
<%- include('partials/header') %>

<section class="section">
  <div class="container" style="max-width:760px;">
    <h2>About Us</h2>
    <p><%= settings.about_text %></p>
  </div>
</section>

<section class="section section-tint">
  <h2>Reviews</h2>
  <p class="sub">What our customers say</p>
  <div class="reviews-marquee">
    <div class="reviews-track" id="reviewsTrack">
      <% testimonials.forEach(t => {
        const headline = t.message.length > 55 ? t.message.slice(0, 55).trim() + '…' : t.message;
        const needsReadMore = t.message.length > 140;
      %>
        <div class="testimonial">
          <div class="quote-mark">&ldquo;</div>
          <div class="review-title"><%= headline %></div>
          <div class="review-body"><%= t.message %></div>
          <% if (needsReadMore) { %>
            <button type="button" class="read-more" onclick="const c=this.closest('.testimonial'); c.classList.toggle('expanded'); this.textContent = c.classList.contains('expanded') ? 'READ LESS' : 'READ MORE';">READ MORE</button>
          <% } %>
          <div class="stars"><%= '★'.repeat(t.rating) %><%= '☆'.repeat(5 - t.rating) %></div>
          <div class="who-row"><span class="who"><%= t.name %></span></div>
          <div class="meta-row">
            <span class="verified">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              Verified
            </span>
            <span class="review-date" data-created="<%= t.created_at %>">just now</span>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <% if (testimonials.length === 0) { %><p class="sub">No reviews yet.</p><% } %>
  <% if (settings.google_business_url) { %>
    <div style="text-align:center; margin-top:24px;">
      <a class="btn btn-outline" href="<%= settings.google_business_url %>" target="_blank" rel="noopener">See All Our Reviews on Google</a>
    </div>
  <% } %>
</section>
<script>
  (function () {
    function timeAgo(iso) {
      const diff = Date.now() - new Date(iso).getTime();
      const day = 86400000;
      const days = Math.floor(diff / day);
      if (days <= 0) return 'Today';
      if (days === 1) return '1 day ago';
      if (days < 30) return days + ' days ago';
      const months = Math.floor(days / 30);
      if (months < 12) return months + (months === 1 ? ' month ago' : ' months ago');
      const years = Math.floor(months / 12);
      return years + (years === 1 ? ' year ago' : ' years ago');
    }
    document.querySelectorAll('.review-date[data-created]').forEach(el => {
      el.textContent = timeAgo(el.getAttribute('data-created'));
    });

    const track = document.getElementById('reviewsTrack');
    if (!track) return;
    Array.from(track.children).forEach(card => track.appendChild(card.cloneNode(true)));
  })();
</script>
<section class="section section-tint">
  <div class="container" style="max-width:760px;">
    <h2>Frequently Asked Questions</h2>
    <p class="sub">Things people usually ask before ordering</p>

    <div class="faq-list">
      <% faqs.forEach(f => { %>
        <details class="faq-item">
          <summary><%= f.question %></summary>
          <p><%= f.answer %></p>
        </details>
      <% }) %>
      <% if (faqs.length === 0) { %><p class="sub">No FAQs added yet.</p><% } %>
    </div>
  </div>
</section>

<% if (faqs.length) { %>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
}) %>
</script>
<% } %>
<section class="section">
  <h2>Leave a Review</h2>
  <p class="sub">Reviews are shown after approval by the team</p>
  <div class="form-box">
    <form action="/testimonials" method="POST">
      <div class="form-group">
        <label>Your Name</label>
        <input type="text" name="name" required>
      </div>
      <div class="form-group">
        <label>Rating</label>
        <select name="rating">
          <option value="5">★★★★★</option>
          <option value="4">★★★★☆</option>
          <option value="3">★★★☆☆</option>
          <option value="2">★★☆☆☆</option>
          <option value="1">★☆☆☆☆</option>
        </select>
      </div>
      <div class="form-group">
        <label>Your Review</label>
        <textarea name="message" required></textarea>
      </div>
      <button class="btn" type="submit">Submit Review</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
