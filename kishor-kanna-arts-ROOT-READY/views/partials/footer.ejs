<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h4><%= settings.site_name %></h4>
      <p style="color:#cfc3b5; font-size:0.9rem;">Custom hand-made art, crafted with love and shipped anywhere.</p>
    </div>
    <div>
      <h4>Explore</h4>
      <a href="/portfolio">Portfolio</a>
      <a href="/services">Services</a>
      <a href="/about">About Us</a>
      <a href="/order">Order Now</a>
      <a href="/track-order">Track Order</a>
    </div>
    <div>
      <h4>Contact</h4>
      <a href="tel:<%= settings.contact_phone %>"><%= settings.contact_phone %></a>
      <a href="mailto:<%= settings.contact_email %>"><%= settings.contact_email %></a>
      <p style="color:#cfc3b5; font-size:0.9rem;"><%= settings.contact_address %></p>
      <a href="/privacy-policy">Privacy Policy</a>
      <a href="/terms">Terms &amp; Conditions</a>
    </div>
    <div>
      <h4>Newsletter</h4>
      <p style="color:#cfc3b5; font-size:0.9rem;">Get notified about new artworks &amp; offers.</p>
      <form class="newsletter-form" action="/newsletter" method="POST">
        <input type="email" name="email" placeholder="Your email" required>
        <button type="submit">Join</button>
      </form>
    </div>
  </div>
  <div class="footer-bottom">
    &copy; <%= new Date().getFullYear() %> <%= settings.site_name %>. All rights reserved.
  </div>
</footer>
</body>
</html>
