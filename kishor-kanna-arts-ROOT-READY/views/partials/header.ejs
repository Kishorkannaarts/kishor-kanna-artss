<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' + settings.site_name : settings.site_name %></title>
<link rel="stylesheet" href="/public/css/style.css">
<style>
  :root {
    --accent: <%= settings.theme_accent || '#b5451b' %>;
    --accent-dark: <%= settings.theme_accent_dark || '#8c3413' %>;
    --gold: <%= settings.theme_gold || '#c99a3a' %>;
    --paper: <%= settings.theme_paper || '#faf6f0' %>;
    --ink: <%= settings.theme_ink || '#221a16' %>;
  }
</style>
</head>
<body>
<header class="site-header">
  <a class="logo" href="/" style="display:flex; align-items:center; gap:10px;">
    <% if (settings.logo_url) { %><img src="<%= settings.logo_url %>" alt="<%= settings.site_name %>" style="height:42px; width:auto;"><% } %>
    <span><%= settings.site_name %></span>
  </a>
  <button class="menu-toggle" onclick="document.querySelector('.nav').classList.toggle('open')">&#9776;</button>
  <nav class="nav">
    <a href="/">Home</a>
    <a href="/portfolio">Portfolio</a>
    <a href="/services">Services</a>
    <a href="/about">About Us</a>
    <a href="/contact">Contact</a>
    <a href="/track-order">Track Order</a>
    <a class="nav-cta" href="/order">Order Now</a>
  </nav>
</header>

<% if (typeof popupOffer !== 'undefined' && popupOffer && !isAdmin) { %>
<div id="offerPopupOverlay" style="display:none; position:fixed; inset:0; background:rgba(20,15,10,0.65); z-index:9999; align-items:center; justify-content:center; padding:20px;">
  <div style="background:#fff; border-radius:16px; max-width:420px; width:100%; overflow:hidden; position:relative; text-align:center; box-shadow:0 24px 70px rgba(0,0,0,0.35);">
    <button onclick="closeOfferPopup()" aria-label="Close" style="position:absolute; top:10px; right:12px; background:rgba(255,255,255,0.92); border:none; border-radius:50%; width:34px; height:34px; font-size:1.3rem; line-height:1; cursor:pointer; box-shadow:0 2px 8px rgba(0,0,0,0.2);">&times;</button>
    <% if (popupOffer.image) { %>
      <img src="<%= popupOffer.image %>" alt="<%= popupOffer.title %>" style="width:100%; height:200px; object-fit:cover; display:block;">
    <% } %>
    <div style="padding:26px 24px 30px;">
      <h3 style="margin:0 0 10px; font-size:1.45rem; color:var(--ink);"><%= popupOffer.title %></h3>
      <% if (popupOffer.message) { %><p style="color:var(--muted); margin:0 0 20px; line-height:1.5;"><%= popupOffer.message %></p><% } %>
      <a href="/order" class="btn" style="display:inline-block;">Order Now</a>
    </div>
  </div>
</div>
<script>
  (function () {
    if (!sessionStorage.getItem('offerPopupDismissed')) {
      setTimeout(function () {
        var el = document.getElementById('offerPopupOverlay');
        if (el) el.style.display = 'flex';
      }, 900);
    }
  })();
  function closeOfferPopup() {
    var el = document.getElementById('offerPopupOverlay');
    if (el) el.style.display = 'none';
    sessionStorage.setItem('offerPopupDismissed', '1');
  }
  document.addEventListener('DOMContentLoaded', function () {
    var overlay = document.getElementById('offerPopupOverlay');
    if (overlay) overlay.addEventListener('click', function (e) { if (e.target === overlay) closeOfferPopup(); });
  });
</script>
<% } %>
