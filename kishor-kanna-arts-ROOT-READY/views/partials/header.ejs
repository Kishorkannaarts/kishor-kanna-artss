<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' + settings.site_name : settings.site_name %></title>
<meta name="description" content="<%= (typeof pageMetaDescription !== 'undefined' && pageMetaDescription) ? pageMetaDescription : settings.meta_description %>">
<meta name="keywords" content="<%= (typeof pageMetaKeywords !== 'undefined' && pageMetaKeywords) ? pageMetaKeywords : settings.meta_keywords %>">
<meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' + settings.site_name : settings.site_name %>">
<meta property="og:description" content="<%= (typeof pageMetaDescription !== 'undefined' && pageMetaDescription) ? pageMetaDescription : settings.meta_description %>">
<meta property="og:type" content="website">
<% if (settings.hero_image_url) { %><meta property="og:image" content="<%= settings.hero_image_url %>"><% } %>
<link rel="stylesheet" href="/public/css/style.css">
<style>
  :root {
    --accent: <%= settings.theme_accent || '#b5451b' %>;
    --accent-dark: <%= settings.theme_accent_dark || '#8c3413' %>;
    --gold: <%= settings.theme_gold || '#c99a3a' %>;
    --paper: <%= settings.theme_paper || '#faf6f0' %>;
    --ink: <%= settings.theme_ink || '#221a16' %>;
  }
</style>
</head>
<body>
<header class="site-header">
  <a class="logo" href="/" style="display:flex; align-items:center; gap:10px;">
    <% if (settings.logo_url) { %><img src="<%= settings.logo_url %>" alt="<%= settings.site_name %>" style="height:42px; width:auto;"><% } %>
    <span><%= settings.site_name %></span>
  </a>
  <button class="menu-toggle" onclick="document.querySelector('.nav').classList.toggle('open')">&#9776;</button>
  <nav class="nav">
    <a href="/">Home</a>
    <a href="/portfolio">Portfolio</a>
    <a href="/services">Services</a>
    <a href="/about">About Us</a>
    <a href="/contact">Contact</a>
    <a href="/track-order">Track Order</a>
    <a class="nav-cta" href="/order">Order Now</a>
  </nav>
</header>

<% if (typeof popupOffer !== 'undefined' && popupOffer && !isAdmin) { %>
<div id="offerPopupOverlay" class="offer-popup-overlay" style="display:none;">
  <div class="offer-popup">
    <button onclick="closeOfferPopup()" aria-label="Close" class="offer-popup-close">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="offer-popup-left">
      <% if (popupOffer.discount_percent) { %>
        <p class="eyebrow">Unlock</p>
        <h2 class="headline"><%= popupOffer.discount_percent %>% Off</h2>
        <p class="subline"><%= popupOffer.title %></p>
      <% } else { %>
        <h2 class="headline" style="font-size:1.9rem;"><%= popupOffer.title %></h2>
      <% } %>
      <% if (popupOffer.message) { %><p style="color:var(--muted); text-align:center; margin:0 0 20px; line-height:1.5;"><%= popupOffer.message %></p><% } %>
      <form action="/newsletter" method="POST">
        <input type="hidden" name="source" value="offer_popup">
        <input type="email" name="email" placeholder="Email address" required>
        <p class="purchased-q">Have you purchased original art before?</p>
        <div class="purchased-options">
          <label><input type="radio" name="purchased_before" value="yes"> Yes</label>
          <label><input type="radio" name="purchased_before" value="no"> No</label>
        </div>
        <button class="btn" type="submit">Unlock My Offer</button>
      </form>
    </div>
    <div class="offer-popup-right" style="background-image: url('<%= popupOffer.image || settings.hero_image_url || 'https://placehold.co/700x800?text=Art' %>');"></div>
  </div>
</div>
<script>
  (function () {
    var dismissKey = 'offerPopupDismissedAt_<%= popupOffer.id %>';
    var params = new URLSearchParams(window.location.search);

    if (params.get('offerClaimed') === '1') {
      // They just submitted the form — don't show it again, and clean the URL.
      localStorage.setItem(dismissKey, String(Date.now()));
      params.delete('offerClaimed');
      var cleanUrl = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
      window.history.replaceState({}, '', cleanUrl);
    }

    var dismissedAt = localStorage.getItem(dismissKey);
    var oneDay = 24 * 60 * 60 * 1000;
    var recentlyDismissed = dismissedAt && (Date.now() - parseInt(dismissedAt, 10) < oneDay);

    if (!recentlyDismissed) {
      setTimeout(function () {
        var el = document.getElementById('offerPopupOverlay');
        if (el) el.style.display = 'flex';
      }, 900);
    }

    window.closeOfferPopup = function () {
      var el = document.getElementById('offerPopupOverlay');
      if (el) el.style.display = 'none';
      localStorage.setItem(dismissKey, String(Date.now()));
    };
  })();
  document.addEventListener('DOMContentLoaded', function () {
    var overlay = document.getElementById('offerPopupOverlay');
    if (overlay) overlay.addEventListener('click', function (e) { if (e.target === overlay) closeOfferPopup(); });
  });
</script>
<% } %>
