<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' + settings.site_name : settings.site_name %></title>

<%
  const _desc = typeof pageDescription !== 'undefined' ? pageDescription
    : (settings.meta_description || `Custom hand-made pencil, colour and canvas portraits by ${settings.site_name}. Made from your photo, shipped anywhere in India.`);
  const _canonical = siteUrl + currentPath;
  const _ogImage = (typeof pageImage !== 'undefined' && pageImage) ? pageImage : (settings.og_image_url || settings.logo_url || '');
  const _isAdminPath = currentPath.indexOf('/admin') === 0;
  const _noIndex = _isAdminPath || currentPath === '/track-order';
%>
<meta name="description" content="<%= _desc %>">
<link rel="canonical" href="<%= _canonical %>">
<% if (_noIndex) { %><meta name="robots" content="noindex, nofollow"><% } %>

<meta property="og:type" content="website">
<meta property="og:site_name" content="<%= settings.site_name %>">
<meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' + settings.site_name : settings.site_name %>">
<meta property="og:description" content="<%= _desc %>">
<meta property="og:url" content="<%= _canonical %>">
<% if (_ogImage) { %><meta property="og:image" content="<%= _ogImage %>"><% } %>

<meta name="twitter:card" content="<% if (_ogImage) { %>summary_large_image<% } else { %>summary<% } %>">
<meta name="twitter:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle + ' | ' + settings.site_name : settings.site_name %>">
<meta name="twitter:description" content="<%= _desc %>">
<% if (_ogImage) { %><meta name="twitter:image" content="<%= _ogImage %>"><% } %>

<% if (!_isAdminPath) { %>
<script type="application/ld+json">
<%- JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": settings.site_name,
  "image": _ogImage || undefined,
  "url": siteUrl,
  "telephone": settings.contact_phone,
  "email": settings.contact_email,
  "address": settings.contact_address,
  "priceRange": "₹₹"
}) %>
</script>
<% } %>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,500;0,600;1,500&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/public/css/style.css">

<% if (!_isAdminPath && settings.ga_measurement_id) { %>
<script async src="https://www.googletagmanager.com/gtag/js?id=<%= settings.ga_measurement_id %>"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '<%= settings.ga_measurement_id %>');
</script>
<% } %>
<% if (!_isAdminPath && settings.meta_pixel_id) { %>
<script>
  !function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?
  n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;
  n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;
  t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,
  document,'script','https://connect.facebook.net/en_US/fbevents.js');
  fbq('init', '<%= settings.meta_pixel_id %>');
  fbq('track', 'PageView');
</script>
<noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=<%= settings.meta_pixel_id %>&ev=PageView&noscript=1"></noscript>
<% } %>

<style>
  :root {
    --accent: <%= settings.theme_accent || '#b5451b' %>;
    --accent-dark: <%= settings.theme_accent_dark || '#8c3413' %>;
    --gold: <%= settings.theme_gold || '#c99a3a' %>;
    --paper: <%= settings.theme_paper || '#faf6f0' %>;
    --ink: <%= settings.theme_ink || '#221a16' %>;
  }
</style>
</head>
<body>
<header class="site-header">
  <a class="logo" href="/" style="display:flex; align-items:center; gap:10px;">
    <% if (settings.logo_url) { %><img src="<%= settings.logo_url %>" alt="<%= settings.site_name %>" style="height:42px; width:auto;"><% } %>
    <span><%= settings.site_name %></span>
  </a>
  <button class="menu-toggle" onclick="document.querySelector('.nav').classList.toggle('open')">&#9776;</button>
  <nav class="nav">
    <a href="/">Home</a>
    <a href="/portfolio">Portfolio</a>
    <a href="/services">Services</a>
    <a href="/blog">Blog</a>
    <% if (settings.courses_enabled) { %><a href="/courses">Courses</a><% } %>
    <a href="/about">About Us</a>
    <a href="/contact">Contact</a>
    <a href="/track-order">Track Order</a>
    <a class="nav-cta" href="/order">Order Now</a>
  </nav>
</header>

<% if (typeof popupOffer !== 'undefined' && popupOffer && !isAdmin) { %>
<div id="offerPopupOverlay" style="display:none; position:fixed; inset:0; background:rgba(10,8,6,0.7); z-index:9999; align-items:center; justify-content:center; padding:20px;">
  <div style="background:#151110; border-radius:18px; max-width:420px; width:100%; overflow:hidden; position:relative; box-shadow:0 24px 70px rgba(0,0,0,0.5); <% if (popupOffer.image) { %>min-height:440px; display:flex; flex-direction:column; justify-content:flex-end;<% } %>">
    <button onclick="closeOfferPopup()" aria-label="Close" style="position:absolute; top:12px; right:12px; z-index:2; background:rgba(255,255,255,0.15); backdrop-filter:blur(4px); border:none; border-radius:50%; width:34px; height:34px; font-size:1.3rem; line-height:1; cursor:pointer; color:#fff;">&times;</button>
    <% if (popupOffer.image) { %>
      <img src="<%= popupOffer.image %>" alt="<%= popupOffer.title %>" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;">
      <div style="position:absolute; inset:0; background:linear-gradient(180deg, rgba(0,0,0,0) 35%, rgba(10,8,6,0.92) 100%);"></div>
    <% } %>
    <div style="position:relative; padding:26px 24px 30px; text-align:center; <% if (!popupOffer.image) { %>padding-top:36px;<% } %>">
      <h3 style="margin:0 0 10px; font-size:1.5rem; color:#fff;"><%= popupOffer.title %></h3>
      <% if (popupOffer.message) { %><p style="color:rgba(255,255,255,0.85); margin:0 0 20px; line-height:1.5;"><%= popupOffer.message %></p><% } %>
      <a href="/order" class="btn" style="display:inline-block;">Order Now</a>
    </div>
  </div>
</div>
<script>
  (function () {
    if (!sessionStorage.getItem('offerPopupShown')) {
      setTimeout(function () {
        var el = document.getElementById('offerPopupOverlay');
        if (el) el.style.display = 'flex';
        sessionStorage.setItem('offerPopupShown', '1');
      }, 900);
    }
  })();
  function closeOfferPopup() {
    var el = document.getElementById('offerPopupOverlay');
    if (el) el.style.display = 'none';
  }
  document.addEventListener('DOMContentLoaded', function () {
  var overlay = document.getElementById('offerPopupOverlay');
  if (overlay) overlay.addEventListener('click', function (e) { if (e.target === overlay) closeOfferPopup(); });
});
</script>
<% } %>
