<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle + ' | ' + settings.site_name : settings.site_name %></title>

<% const metaDesc = (typeof metaDescription !== 'undefined' && metaDescription) ? metaDescription : (settings.site_description || 'Custom handmade pencil, color and canvas portraits by Kishor Kanna Arts. Pet, couple, family and wedding portraits, made with love and shipped across India.'); %>
<% const ogImg = (typeof ogImage !== 'undefined' && ogImage) ? ogImage : (settings.logo_url || ''); %>
<meta name="description" content="<%= metaDesc %>">
<meta name="robots" content="index, follow">
<% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %><link rel="canonical" href="<%= canonicalUrl %>"><% } %>

<!-- Open Graph -->
<meta property="og:type" content="website">
<meta property="og:site_name" content="<%= settings.site_name %>">
<meta property="og:title" content="<%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : settings.site_name %>">
<meta property="og:description" content="<%= metaDesc %>">
<% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %><meta property="og:url" content="<%= canonicalUrl %>"><% } %>
<% if (ogImg) { %><meta property="og:image" content="<%= ogImg %>"><% } %>

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="<%= typeof pageTitle !== 'undefined' && pageTitle ? pageTitle : settings.site_name %>">
<meta name="twitter:description" content="<%= metaDesc %>">
<% if (ogImg) { %><meta name="twitter:image" content="<%= ogImg %>"><% } %>

<!-- Organization schema (site-wide, helps Google show your logo, socials, contact info in search) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "<%= settings.site_name %>",
  <% if (siteUrl) { %>"url": "<%= siteUrl %>",<% } %>
  <% if (ogImg) { %>"logo": "<%= ogImg %>",<% } %>
  "description": "<%= metaDesc.replace(/"/g, '\\"') %>"<% if (settings.contact_phone || settings.contact_email) { %>,
  "contactPoint": {
    "@type": "ContactPoint",
    <% if (settings.contact_phone) { %>"telephone": "<%= settings.contact_phone %>",<% } %>
    "contactType": "customer service"<% if (settings.contact_email) { %>,
    "email": "<%= settings.contact_email %>"<% } %>
  }<% } %>
}
</script>
<% if (typeof extraSchema !== 'undefined' && extraSchema) { %>
<script type="application/ld+json"><%- extraSchema %></script>
<% } %>

<link rel="stylesheet" href="/public/css/style.css">
<style>
  :root {
    --accent: <%= settings.theme_accent || '#b5451b' %>;
    --accent-dark: <%= settings.theme_accent_dark || '#8c3413' %>;
    --gold: <%= settings.theme_gold || '#c99a3a' %>;
    --paper: <%= settings.theme_paper || '#faf6f0' %>;
    --ink: <%= settings.theme_ink || '#221a16' %>;
  }
</style>
</head>
<body>
<header class="site-header">
  <a class="logo" href="/" style="display:flex; align-items:center; gap:10px;">
    <% if (settings.logo_url) { %><img src="<%= settings.logo_url %>" alt="<%= settings.site_name %>" style="height:42px; width:auto;"><% } %>
    <span><%= settings.site_name %></span>
  </a>
  <button class="menu-toggle" onclick="document.querySelector('.nav').classList.toggle('open')">&#9776;</button>
  <nav class="nav">
    <a href="/">Home</a>
    <a href="/portfolio">Portfolio</a>
    <a href="/services">Services</a>
    <a href="/blog">Blog</a>
    <a href="/about">About Us</a>
    <a href="/contact">Contact</a>
    <a href="/track-order">Track Order</a>
    <a class="nav-cta" href="/order">Order Now</a>
  </nav>
</header>

<% if (typeof popupOffer !== 'undefined' && popupOffer && !isAdmin) { %>
<div id="offerPopupOverlay" style="display:none; position:fixed; inset:0; background:rgba(10,8,6,0.7); z-index:9999; align-items:center; justify-content:center; padding:20px;">
  <div style="background:#151110; border-radius:18px; max-width:420px; width:100%; overflow:hidden; position:relative; box-shadow:0 24px 70px rgba(0,0,0,0.5); <% if (popupOffer.image) { %>min-height:440px; display:flex; flex-direction:column; justify-content:flex-end;<% } %>">
    <button onclick="closeOfferPopup()" aria-label="Close" style="position:absolute; top:12px; right:12px; z-index:2; background:rgba(255,255,255,0.15); backdrop-filter:blur(4px); border:none; border-radius:50%; width:34px; height:34px; font-size:1.3rem; line-height:1; cursor:pointer; color:#fff;">&times;</button>
    <% if (popupOffer.image) { %>
      <img src="<%= popupOffer.image %>" alt="<%= popupOffer.title %>" style="position:absolute; inset:0; width:100%; height:100%; object-fit:cover;">
      <div style="position:absolute; inset:0; background:linear-gradient(180deg, rgba(0,0,0,0) 35%, rgba(10,8,6,0.92) 100%);"></div>
    <% } %>
    <div style="position:relative; padding:26px 24px 30px; text-align:center; <% if (!popupOffer.image) { %>padding-top:36px;<% } %>">
      <h3 style="margin:0 0 10px; font-size:1.5rem; color:#fff;"><%= popupOffer.title %></h3>
      <% if (popupOffer.message) { %><p style="color:rgba(255,255,255,0.85); margin:0 0 20px; line-height:1.5;"><%= popupOffer.message %></p><% } %>
      <a href="/order" class="btn" style="display:inline-block;">Order Now</a>
    </div>
  </div>
</div>
<script>
  (function () {
    if (!sessionStorage.getItem('offerPopupShown')) {
      setTimeout(function () {
        var el = document.getElementById('offerPopupOverlay');
        if (el) el.style.display = 'flex';
        sessionStorage.setItem('offerPopupShown', '1');
      }, 900);
    }
  })();
  function closeOfferPopup() {
    var el = document.getElementById('offerPopupOverlay');
    if (el) el.style.display = 'none';
  }
  document.addEventListener('DOMContentLoaded', function () {
    var overlay = document.getElementById('offerPopupOverlay');
    if (overlay) overlay.addEventListener('click', function (e) { if (e.target === overlay) closeOfferPopup(); });
  });
</script>
<% } %>
