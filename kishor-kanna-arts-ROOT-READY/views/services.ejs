<% pageTitle = 'Services' %>
<%- include('partials/header') %>

<section class="section">
  <h2>Services</h2>
  <p class="sub">Choose a service and size to get started</p>
  <div class="grid grid-services">
    <% services.forEach(s => { %>
      <div class="card">
        <img src="<%= s.image || 'https://placehold.co/400x300?text=Service' %>" alt="<%= s.title %>">
        <div class="card-body">
          <h3><%= s.title %></h3>
          <p><%= s.description %></p>
          <table style="width:100%; font-size:0.9rem; margin-bottom:14px;">
            <% if (s.price_a5) { %><tr><td>A5</td><td style="text-align:right;"><%= s.price_a5 %></td></tr><% } %>
            <% if (s.price_a4) { %><tr><td>A4</td><td style="text-align:right;"><%= s.price_a4 %></td></tr><% } %>
            <% if (s.price_a3) { %><tr><td>A3</td><td style="text-align:right;"><%= s.price_a3 %></td></tr><% } %>
            <% if (s.price_custom) { %><tr><td>Custom</td><td style="text-align:right;"><%= s.price_custom %></td></tr><% } %>
          </table>
          <a class="btn" href="/order">Order</a>
        </div>
      </div>
    <% }) %>
    <% if (services.length === 0) { %>
      <p class="sub">No services added yet.</p>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
