<% pageTitle = 'Services' %>
<% pageDescription = `Custom art services from ${settings.site_name} — pencil portraits, colour portraits, canvas paintings, pet and family portraits, and corporate gifting.` %>
<%- include('partials/header') %>

<section class="section">
  <h2>Services</h2>
  <p class="sub">Choose a service and size to get started</p>
  <div class="grid grid-services">
    <% services.forEach(s => { %>
      <div class="card">
        <img src="<%= s.image || 'https://placehold.co/400x300?text=Service' %>" alt="<%= s.title %>" loading="lazy" decoding="async">
        <div class="card-body">
          <h3><%= s.title %></h3>
          <p><%= s.description %></p>
          <table style="width:100%; font-size:0.9rem; margin-bottom:14px;">
            <% sizes.forEach(sz => { const p = priceForSize(s, sz); %>
              <% if (p) { %><tr><td><%= sz %></td><td style="text-align:right;"><%= sz.toLowerCase() === 'custom' ? 'from ' + p : p %></td></tr><% } %>
            <% }) %>
          </table>
          <% if (priceForSize(s, sizes.find(sz => sz.toLowerCase() === 'custom') || 'Custom')) { %><p class="sub" style="text-align:left; font-size:0.8rem; margin:-8px 0 12px;">Custom sizes: final price confirmed after we review your request.</p><% } %>
          <a class="btn" href="/order">Order</a>
        </div>
      </div>
    <% }) %>
    <% if (services.length === 0) { %>
      <p class="sub">No services added yet.</p>
    <% } %>
  </div>
</section>

<%- include('partials/footer') %>
